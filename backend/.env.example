# Django
DJANGO_SECRET_KEY=replace-with-secure-random-value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,btcforecastapi.duckdns.org,btcforecast.duckdns.org

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://btcforecast.duckdns.org,https://btcforecastapi.duckdns.org
CSRF_TRUSTED_ORIGINS=https://btcforecast.duckdns.org,https://btcforecastapi.duckdns.org

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
